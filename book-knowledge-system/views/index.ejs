<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Book System</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <header>
    <h1>📚 My Book Knowledge System</h1>
    <a href="/add">Add Book</a>
  </header>

  <section class="controls">
    <input type="text" placeholder="Search books..." id="searchInput">
    
    <select id="sortSelect">
      <option value="recent">Sort by Recency</option>
      <option value="rating">Sort by Rating</option>
    </select>
  </section>

  <section class="book-container" id="bookContainer">
    
    <!-- Example Card -->
    <div class="book-card">
      <img src="https://covers.openlibrary.org/b/isbn/0385472579-L.jpg" alt="Book Cover">
      <h3>Book Title</h3>
      <p>Author Name</p>
      <p>⭐ 4.5</p>
      <p class="tags">#psychology #growth</p>
      
      <div class="actions">
        <a href="/edit"><button>Edit</button></a>
        <button class="delete" data-id="BOOK_ID">Delete</button>
      </div>
    </div>

  </section>

  <script src="/js/main.js"></script>
</body>
</html>