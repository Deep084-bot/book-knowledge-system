<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Book System</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <header>
    <h1>📚 My Book Knowledge System</h1>
    <a href="/add">Add Book</a>
  </header>

  <section class="controls">
    <input type="text" placeholder="Search books..." id="searchInput">
    
    <select id="sortSelect">
      <option value="recent">Sort by Recency</option>
      <option value="rating">Sort by Rating</option>
    </select>
  </section>

  <section class="book-container" id="bookContainer">
    <% if(locals.books) {%>
    <% books.forEach(book => { %>
      <div class="book-card">
        <img src="<%= book.cover_url %>" alt="Book Cover">

        <h3><%= book.title %></h3>
        <p><%= book.author %></p>
        <p>⭐ <%= book.rating %></p>

        <p class="tags">
          <% book.tags.forEach(tag => { %>
            #<%= tag %>
          <% }) %>
        </p>

        <div class="actions">
          <a href="/edit/<%= book.id %>">
            <button>Edit</button>
          </a>

          <button class="delete" data-id="<%= book.id %>">
            Delete
          </button>
        </div>
      </div>
    <% }) %>
    <% } %>

  </section>

  <script src="/js/main.js"></script>
</body>
</html>