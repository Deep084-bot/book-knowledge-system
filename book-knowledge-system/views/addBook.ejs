<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add Book</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <h2>Add New Book</h2>

  <form id="bookForm" action="/books" method="POST">
    <input type="text" placeholder="Book Title" name="title" required>
    <input type="text" placeholder="Author" name="author" required>
    
    <input type="number" placeholder="Rating (1-5)" name="rating" min="1" max="5">

    <input type="text" placeholder="Tags (comma separated)" name="tags">

    <textarea placeholder="Your Notes..." name="notes"></textarea>

    <button type="submit">Save</button>
  </form>

</body>
</html>